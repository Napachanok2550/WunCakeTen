<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>

<VBox spacing="12"
      xmlns="http://javafx.com/javafx"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.project.HistoryController"
      styleClass="root">

    <padding>
        <Insets top="18" right="18" bottom="18" left="18"/>
    </padding>

    <Label text="ประวัติย้อนหลัง" styleClass="title"/>

    <TableView fx:id="table" prefHeight="420">
        <columns>
            <TableColumn fx:id="colDate" text="วันที่" prefWidth="120"/>
            <TableColumn fx:id="colQuestion" text="คำถาม" prefWidth="300"/>
            <TableColumn fx:id="colAnswer" text="คำตอบ" prefWidth="300"/>
            <TableColumn fx:id="colMood" text="อารมณ์" prefWidth="80"/>
        </columns>
    </TableView>

    <HBox spacing="10">
        <Button text="แก้ไข" onAction="#onEdit"/>
        <Button text="ลบ" onAction="#onDelete"/>
        <Pane HBox.hgrow="ALWAYS"/>
        <Button text="กลับ" onAction="#onBack"/>
    </HBox>

</VBox>